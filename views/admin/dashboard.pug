extends ../layouts/layout

block content
  h1 Admin Dashboard
  p.muted Signed in as #{currentUserEmail}

  if bookings && bookings.length
    .admin-table-card
      h2 Booking List
      p.muted Latest bookings ordered by most recent.
      table.admin-table
        thead
          tr
            th Date
            th Name
            th Vehicle
            th Service
            th Notes
            th Photo
        tbody
          each b in bookings
            tr
              td= b.date.toDateString ? b.date.toDateString() : b.date
              td= b.name
              td= b.vehicle
              td= b.service
              td= b.notes || "-"
              td
                if b.photo
                  img(src="/uploads/" + b.photo, style="width:80px;border-radius:8px;object-fit:cover;")
                else
                  span -
  else
    p No bookings yet.