extends ../layouts/layout

block content
  h1 Register Admin
  if error
    p.error= error
  form(action="/register", method="post")
    label Email
      input(type="email", name="email", required)
    label Password
      input(type="password", name="password", required)
    button.btn(type="submit") Register
  p.muted
    | Already have an account? 
    a(href="/login") Log in